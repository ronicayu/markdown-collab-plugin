{
  "name": "markdown-collab-plugin",
  "displayName": "Markdown Collab",
  "description": "Review Markdown with Claude Code — inline comments, a live AI co-editor, and GitHub/GitLab PR review, all anchored in the file.",
  "version": "0.34.17",
  "icon": "media/icon.png",
  "publisher": "markdown-collab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ronicayu/markdown-collab-plugin.git"
  },
  "homepage": "https://github.com/ronicayu/markdown-collab-plugin#readme",
  "bugs": {
    "url": "https://github.com/ronicayu/markdown-collab-plugin/issues"
  },
  "engines": {
    "vscode": "^1.80.0",
    "node": ">=20"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "review",
    "comments",
    "claude",
    "ai",
    "collaboration",
    "pull request",
    "code review",
    "wysiwyg",
    "gitlab"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:markdownCollab.installClaudeSkill",
    "onCommand:markdownCollab.initializeAgents",
    "onCommand:markdownCollab.copyClaudePrompt",
    "onCommand:markdownCollab.sendAllToClaude",
    "onCommand:markdownCollab.startClaudeTerminal",
    "onCommand:markdownCollab.resetSendMode",
    "onView:markdownCollab.review",
    "onCommand:markdownCollab.openCollabEditor",
    "onCustomEditor:markdownCollab.collabEditor",
    "onCommand:markdownCollab.openInlineCommentsView",
    "onCommand:markdownCollab.askClaudeToReview",
    "onCommand:markdownCollab.startPrReview",
    "onView:markdownCollab.prReviewFiles"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownCollab.installClaudeSkill",
        "title": "Markdown Collab: Install Claude Skill"
      },
      {
        "command": "markdownCollab.initializeAgents",
        "title": "Markdown Collab: Initialize AGENTS.md"
      },
      {
        "command": "markdownCollab.copyClaudePrompt",
        "title": "Markdown Collab: Copy Claude Prompt"
      },
      {
        "command": "markdownCollab.revealComment",
        "title": "Reveal Markdown Comment"
      },
      {
        "command": "markdownCollab.sendAllToClaude",
        "title": "Markdown Collab: Send Unresolved Comments to Claude"
      },
      {
        "command": "markdownCollab.startClaudeTerminal",
        "title": "Markdown Collab: Start Claude Review Terminal"
      },
      {
        "command": "markdownCollab.resetSendMode",
        "title": "Markdown Collab: Reset Send Mode"
      },
      {
        "command": "markdownCollab.openCollabEditor",
        "title": "Markdown Collab: Open Live Editor",
        "category": "Markdown Collab"
      },
      {
        "command": "markdownCollab.openInlineCommentsView",
        "title": "Markdown Collab: Open Inline Comments View",
        "category": "Markdown Collab"
      },
      {
        "command": "markdownCollab.askClaudeToReview",
        "title": "Markdown Collab: Ask Claude to Review This Doc",
        "category": "Markdown Collab"
      },
      {
        "command": "markdownCollab.startPrReview",
        "title": "Markdown Collab: Review PR / MR",
        "category": "Markdown Collab"
      },
      {
        "command": "markdownCollab.prReviewAddComment",
        "title": "Add"
      },
      {
        "command": "markdownCollab.prReviewEditComment",
        "title": "Edit",
        "icon": "$(edit)"
      },
      {
        "command": "markdownCollab.prReviewSaveEdit",
        "title": "Save"
      },
      {
        "command": "markdownCollab.prReviewCancelEdit",
        "title": "Cancel"
      },
      {
        "command": "markdownCollab.prReviewDeleteComment",
        "title": "Delete draft",
        "icon": "$(trash)"
      },
      {
        "command": "markdownCollab.openPrReviewFile",
        "title": "Open in PR review"
      },
      {
        "command": "markdownCollab.prReviewRefresh",
        "title": "Refresh Changed Files",
        "category": "Markdown Collab",
        "icon": "$(refresh)"
      }
    ],
    "configuration": {
      "title": "Markdown Collab",
      "properties": {
        "markdownCollab.sendMode": {
          "type": "string",
          "enum": [
            "ask",
            "terminal",
            "channel",
            "mcp-channel",
            "clipboard"
          ],
          "enumDescriptions": [
            "Prompt the first time per workspace, then remember the choice. Run 'Markdown Collab: Reset Send Mode' to clear the remembered choice.",
            "Type the prompt into a running Claude REPL via bracketed paste. Falls back to spawning a 'Claude Review' terminal if none is detected.",
            "Append one JSON line per click to .markdown-collab/.events.jsonl. Claude reads it via the bundled mdc-tail.mjs in a background bash + Monitor — no polling, no Bash 600s timeout.",
            "Push the payload to the bundled MCP channel server so Claude receives a native <channel> tag on its next turn. Requires Claude Code v2.1.80+ and a one-time .mcp.json setup (see README).",
            "Copy the prompt to the clipboard for manual paste into Claude."
          ],
          "default": "ask",
          "markdownDescription": "How the **Send to Claude** button delivers unresolved comments to Claude Code.\n\n- `ask` — quick-pick on first use per workspace; remembers the choice (run **Markdown Collab: Reset Send Mode** to clear).\n- `terminal` — bracketed-paste into a running `claude` REPL. No MCP required.\n- `channel` — append to `.markdown-collab/.events.jsonl` for a `tail` + `Monitor` watch loop. No MCP required, but needs a streaming-tool harness.\n- `mcp-channel` — native MCP channel: events arrive as `<channel source=\"markdown-collab\">` tags. Requires Claude Code v2.1.80+, claude.ai login, and a one-time `.mcp.json` setup.\n- `clipboard` — copy the prompt for manual paste."
        },
        "markdownCollab.collab.userName": {
          "type": "string",
          "default": "",
          "description": "Display name attributed to your comments in the live editor. Defaults to your OS username."
        },
        "markdownCollab.plantuml.serverUrl": {
          "type": "string",
          "default": "https://www.plantuml.com/plantuml",
          "description": "PlantUML server used to render `plantuml`/`puml` fenced code blocks in every preview surface (legacy preview, inline-comments view, PR review preview). Defaults to the public instance. Point at a self-hosted server (e.g. http://localhost:8080) to keep your diagrams off the public web."
        },
        "markdownCollab.plantuml.format": {
          "type": "string",
          "enum": ["svg", "png"],
          "default": "svg",
          "description": "Image format requested from the PlantUML server. SVG scales better; PNG is heavier but renders identically on every browser."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "markdownCollab.revealComment",
          "when": "false"
        },
        {
          "command": "markdownCollab.prReviewAddComment",
          "when": "false"
        },
        {
          "command": "markdownCollab.prReviewEditComment",
          "when": "false"
        },
        {
          "command": "markdownCollab.prReviewSaveEdit",
          "when": "false"
        },
        {
          "command": "markdownCollab.prReviewCancelEdit",
          "when": "false"
        },
        {
          "command": "markdownCollab.prReviewDeleteComment",
          "when": "false"
        },
        {
          "command": "markdownCollab.openPrReviewFile",
          "when": "false"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "markdownCollab.prReviewAddComment",
          "group": "inline",
          "when": "commentController == markdown-collab-pr && commentThreadIsEmpty"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "markdownCollab.prReviewDeleteComment",
          "group": "inline@1",
          "when": "commentController == markdown-collab-pr && !commentThreadIsEmpty"
        }
      ],
      "comments/comment/title": [
        {
          "command": "markdownCollab.prReviewEditComment",
          "group": "group@1",
          "when": "commentController == markdown-collab-pr && comment == prDraft"
        }
      ],
      "comments/comment/context": [
        {
          "command": "markdownCollab.prReviewSaveEdit",
          "group": "inline@1",
          "when": "commentController == markdown-collab-pr && comment == prDraft"
        },
        {
          "command": "markdownCollab.prReviewCancelEdit",
          "group": "inline@2",
          "when": "commentController == markdown-collab-pr && comment == prDraft"
        }
      ],
      "view/title": [
        {
          "command": "markdownCollab.prReviewRefresh",
          "when": "view == markdownCollab.prReviewFiles",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "markdownCollab.openInlineCommentsView",
          "when": "resourceExtname == .md",
          "group": "navigation@30"
        },
        {
          "command": "markdownCollab.askClaudeToReview",
          "when": "resourceExtname == .md",
          "group": "navigation@31"
        }
      ],
      "editor/title/context": [
        {
          "command": "markdownCollab.openInlineCommentsView",
          "when": "resourceExtname == .md",
          "group": "1_open@1"
        },
        {
          "command": "markdownCollab.askClaudeToReview",
          "when": "resourceExtname == .md",
          "group": "1_open@2"
        }
      ],
      "editor/context": [
        {
          "command": "markdownCollab.openInlineCommentsView",
          "when": "resourceLangId == markdown",
          "group": "navigation@30"
        },
        {
          "command": "markdownCollab.askClaudeToReview",
          "when": "resourceLangId == markdown",
          "group": "navigation@31"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "markdownCollab.review",
          "name": "Markdown Review",
          "when": "markdownCollab.hasReview"
        },
        {
          "id": "markdownCollab.prReviewFiles",
          "name": "PR Review (markdown files)"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "markdownCollab.collabEditor",
        "displayName": "Markdown Collab (live editor)",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p . && tsc -p tsconfig.webview.json && npm run bundle:extension && npm run bundle:webview && npm run bundle:inline-comments && npm run bundle:pr-review && npm run copy:fixtures",
    "watch": "tsc -w -p .",
    "bundle:extension": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node20 --external:vscode --external:bufferutil --external:utf-8-validate --outfile=out/extension.js --minify --sourcemap=linked --legal-comments=none",
    "bundle:webview": "esbuild src/webview/client.ts --bundle --format=iife --outfile=out/webview/client.js --target=es2020 --platform=browser --minify --sourcemap=linked --legal-comments=none && node -e \"require('fs').mkdirSync('out/webview',{recursive:true}); require('fs').copyFileSync('src/webviewShared/comments.css','out/webview/comments-shared.css')\"",
    "bundle:webview:watch": "npm run bundle:webview -- --watch",
    "bundle:inline-comments": "esbuild src/inlineComments/webview/client.ts --bundle --format=iife --outfile=out/inlineComments/client.js --target=es2020 --platform=browser --minify --sourcemap=linked --legal-comments=none && node -e \"const fs=require('fs');fs.copyFileSync('src/inlineComments/webview/client.css','out/inlineComments/client.css');fs.copyFileSync('src/webviewShared/comments.css','out/inlineComments/comments-shared.css')\"",
    "bundle:pr-review": "esbuild src/pr/webview/client.ts --bundle --format=iife --outfile=out/pr/webview/client.js --target=es2020 --platform=browser --minify --sourcemap=linked --legal-comments=none && node -e \"const fs=require('fs');fs.mkdirSync('out/pr/webview',{recursive:true});fs.copyFileSync('src/pr/webview/client.css','out/pr/webview/client.css');fs.copyFileSync('src/webviewShared/comments.css','out/pr/webview/comments-shared.css')\"",
    "copy:fixtures": "node -e \"const fs=require('fs'),p=require('path');function cp(s,d){fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s,{withFileTypes:true})){const ss=p.join(s,f.name),dd=p.join(d,f.name);if(f.isDirectory())cp(ss,dd);else fs.copyFileSync(ss,dd);}}cp('src/test/integration/fixtures','out/test/integration/fixtures')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "npm run compile && node ./out/test/integration/runTest.js"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@milkdown/kit": "^7.20.0",
    "@milkdown/plugin-collab": "^7.20.0",
    "@milkdown/theme-nord": "^7.20.0",
    "@types/glob": "^8.1.0",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/pako": "^2.0.4",
    "@types/vscode": "^1.80.0",
    "@types/ws": "^8.18.1",
    "@vscode/test-electron": "^2.5.2",
    "codemirror": "^6.0.2",
    "esbuild": "^0.28.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.8",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "y-codemirror.next": "^0.3.5",
    "y-prosemirror": "^1.3.7",
    "y-websocket": "^3.0.0"
  },
  "dependencies": {
    "markdown-it": "^14.1.1",
    "mermaid": "^11.14.0",
    "mxgraph": "^4.2.2",
    "pako": "^2.1.0",
    "ws": "^8.20.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
  }
}
