{
  "name": "markdown-collab-plugin",
  "displayName": "Markdown Collab",
  "description": "Review comments on Markdown files that Claude Code can read and act on.",
  "version": "0.19.1",
  "publisher": "markdown-collab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ronicayu/markdown-collab-plugin.git"
  },
  "homepage": "https://github.com/ronicayu/markdown-collab-plugin#readme",
  "bugs": {
    "url": "https://github.com/ronicayu/markdown-collab-plugin/issues"
  },
  "engines": {
    "vscode": "^1.80.0",
    "node": ">=20"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "review",
    "comments",
    "claude",
    "ai",
    "collaboration"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:markdownCollab.installClaudeSkill",
    "onCommand:markdownCollab.initializeAgents",
    "onCommand:markdownCollab.validate",
    "onCommand:markdownCollab.copyClaudePrompt",
    "onCommand:markdownCollab.reloadComments",
    "onCommand:markdownCollab.openPreview",
    "onCommand:markdownCollab.sendAllToClaude",
    "onCommand:markdownCollab.startClaudeTerminal",
    "onCommand:markdownCollab.resetSendMode",
    "onView:markdownCollab.review",
    "onCommand:markdownCollab.openCollabEditor",
    "onCustomEditor:markdownCollab.collabEditor"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownCollab.installClaudeSkill",
        "title": "Markdown Collab: Install Claude Skill"
      },
      {
        "command": "markdownCollab.initializeAgents",
        "title": "Markdown Collab: Initialize AGENTS.md"
      },
      {
        "command": "markdownCollab.copyClaudePrompt",
        "title": "Markdown Collab: Copy Claude Prompt"
      },
      {
        "command": "markdownCollab.reloadComments",
        "title": "Markdown Collab: Reload Comments"
      },
      {
        "command": "markdownCollab.validate",
        "title": "Markdown Collab: Validate Sidecars"
      },
      {
        "command": "markdownCollab.openPreview",
        "title": "Markdown Collab: Open Preview with Comments",
        "category": "Markdown Collab"
      },
      {
        "command": "markdownCollab.reattachOrphan",
        "title": "Re-attach Orphaned Comment"
      },
      {
        "command": "markdownCollab.revealComment",
        "title": "Reveal Markdown Comment"
      },
      {
        "command": "markdownCollab.createThread",
        "title": "Add Comment"
      },
      {
        "command": "markdownCollab.addReply",
        "title": "Reply"
      },
      {
        "command": "markdownCollab.toggleResolve",
        "title": "Toggle Resolved"
      },
      {
        "command": "markdownCollab.deleteThread",
        "title": "Delete Comment",
        "icon": "$(trash)"
      },
      {
        "command": "markdownCollab.editComment",
        "title": "Edit",
        "icon": "$(edit)"
      },
      {
        "command": "markdownCollab.saveEdit",
        "title": "Save"
      },
      {
        "command": "markdownCollab.cancelEdit",
        "title": "Cancel"
      },
      {
        "command": "markdownCollab.sendAllToClaude",
        "title": "Markdown Collab: Send Unresolved Comments to Claude"
      },
      {
        "command": "markdownCollab.startClaudeTerminal",
        "title": "Markdown Collab: Start Claude Review Terminal"
      },
      {
        "command": "markdownCollab.resetSendMode",
        "title": "Markdown Collab: Reset Send Mode"
      },
      {
        "command": "markdownCollab.openCollabEditor",
        "title": "Markdown Collab: Open Collaborative Editor (experimental)",
        "category": "Markdown Collab"
      }
    ],
    "configuration": {
      "title": "Markdown Collab",
      "properties": {
        "markdownCollab.sendMode": {
          "type": "string",
          "enum": [
            "ask",
            "terminal",
            "channel",
            "mcp-channel",
            "clipboard"
          ],
          "enumDescriptions": [
            "Prompt the first time per workspace, then remember the choice. Run 'Markdown Collab: Reset Send Mode' to clear the remembered choice.",
            "Type the prompt into a running Claude REPL via bracketed paste. Falls back to spawning a 'Claude Review' terminal if none is detected.",
            "Append one JSON line per click to .markdown-collab/.events.jsonl. Claude reads it via the bundled mdc-tail.mjs in a background bash + Monitor — no polling, no Bash 600s timeout.",
            "Push the payload to the bundled MCP channel server so Claude receives a native <channel> tag on its next turn. Requires Claude Code v2.1.80+ and a one-time .mcp.json setup (see README).",
            "Copy the prompt to the clipboard for manual paste into Claude."
          ],
          "default": "ask",
          "markdownDescription": "How the **Send to Claude** button delivers unresolved comments to Claude Code.\n\n- `ask` — quick-pick on first use per workspace; remembers the choice (run **Markdown Collab: Reset Send Mode** to clear).\n- `terminal` — bracketed-paste into a running `claude` REPL. No MCP required.\n- `channel` — append to `.markdown-collab/.events.jsonl` for a `tail` + `Monitor` watch loop. No MCP required, but needs a streaming-tool harness.\n- `mcp-channel` — native MCP channel: events arrive as `<channel source=\"markdown-collab\">` tags. Requires Claude Code v2.1.80+, claude.ai login, and a one-time `.mcp.json` setup.\n- `clipboard` — copy the prompt for manual paste."
        },
        "markdownCollab.collab.serverUrl": {
          "type": "string",
          "default": "ws://localhost:1234",
          "description": "y-websocket server URL the collaborative editor connects to. The extension can also spawn a local server on activation (see startLocalServer/port). Point this at a remote URL to share with other machines."
        },
        "markdownCollab.collab.startLocalServer": {
          "type": "boolean",
          "default": true,
          "description": "Spawn a local y-websocket server on activation (uses markdownCollab.collab.port)."
        },
        "markdownCollab.collab.port": {
          "type": "number",
          "default": 1234,
          "description": "Port the local y-websocket server binds to. Change if 1234 is in use by another tool. The webview connects to markdownCollab.collab.serverUrl, so update both if you change this."
        },
        "markdownCollab.collab.userName": {
          "type": "string",
          "default": "",
          "description": "Display name shown to other collaborators. Defaults to OS username."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "markdownCollab.createThread",
          "when": "false"
        },
        {
          "command": "markdownCollab.addReply",
          "when": "false"
        },
        {
          "command": "markdownCollab.toggleResolve",
          "when": "false"
        },
        {
          "command": "markdownCollab.deleteThread",
          "when": "false"
        },
        {
          "command": "markdownCollab.editComment",
          "when": "false"
        },
        {
          "command": "markdownCollab.saveEdit",
          "when": "false"
        },
        {
          "command": "markdownCollab.cancelEdit",
          "when": "false"
        },
        {
          "command": "markdownCollab.reattachOrphan",
          "when": "false"
        },
        {
          "command": "markdownCollab.revealComment",
          "when": "false"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "markdownCollab.createThread",
          "group": "inline",
          "when": "commentController == markdown-collab && commentThreadIsEmpty"
        },
        {
          "command": "markdownCollab.addReply",
          "group": "inline",
          "when": "commentController == markdown-collab && !commentThreadIsEmpty && commentThread != markdown-collab-readonly"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "markdownCollab.toggleResolve",
          "group": "inline@1",
          "when": "commentController == markdown-collab && !commentThreadIsEmpty && commentThread != markdown-collab-readonly"
        },
        {
          "command": "markdownCollab.deleteThread",
          "group": "inline@2",
          "when": "commentController == markdown-collab && !commentThreadIsEmpty && commentThread != markdown-collab-readonly"
        }
      ],
      "comments/comment/title": [
        {
          "command": "markdownCollab.editComment",
          "group": "group@1",
          "when": "commentController == markdown-collab && comment == markdown-collab-editable"
        }
      ],
      "comments/comment/context": [
        {
          "command": "markdownCollab.saveEdit",
          "group": "inline@1",
          "when": "commentController == markdown-collab && comment == markdown-collab-editing"
        },
        {
          "command": "markdownCollab.cancelEdit",
          "group": "inline@2",
          "when": "commentController == markdown-collab && comment == markdown-collab-editing"
        }
      ],
      "view/item/context": [
        {
          "command": "markdownCollab.reattachOrphan",
          "when": "view == markdownCollab.orphanedComments && viewItem == markdownCollab.orphanComment",
          "group": "inline"
        }
      ],
      "explorer/context": [
        {
          "command": "markdownCollab.openPreview",
          "when": "resourceExtname == .md",
          "group": "navigation@30"
        }
      ],
      "editor/title/context": [
        {
          "command": "markdownCollab.openPreview",
          "when": "resourceExtname == .md",
          "group": "1_open"
        }
      ],
      "editor/context": [
        {
          "command": "markdownCollab.openPreview",
          "when": "resourceLangId == markdown",
          "group": "navigation@30"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "markdownCollab.orphanedComments",
          "name": "Orphaned Markdown Comments",
          "when": "markdownCollab.hasOrphans"
        },
        {
          "id": "markdownCollab.review",
          "name": "Markdown Review",
          "when": "markdownCollab.hasReview"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "markdownCollab.collabEditor",
        "displayName": "Markdown Collab (real-time, experimental)",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p . && tsc -p tsconfig.webview.json && npm run bundle:webview && npm run copy:fixtures",
    "watch": "tsc -w -p .",
    "bundle:webview": "esbuild src/webview/client.ts --bundle --format=iife --outfile=out/webview/client.js --target=es2020 --platform=browser --minify --sourcemap=linked --legal-comments=none",
    "bundle:webview:watch": "npm run bundle:webview -- --watch",
    "copy:fixtures": "node -e \"const fs=require('fs'),p=require('path');function cp(s,d){fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s,{withFileTypes:true})){const ss=p.join(s,f.name),dd=p.join(d,f.name);if(f.isDirectory())cp(ss,dd);else fs.copyFileSync(ss,dd);}}cp('src/test/integration/fixtures','out/test/integration/fixtures')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "npm run compile && node ./out/test/integration/runTest.js"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@milkdown/kit": "^7.20.0",
    "@milkdown/plugin-collab": "^7.20.0",
    "@milkdown/theme-nord": "^7.20.0",
    "@types/glob": "^8.1.0",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.80.0",
    "@types/ws": "^8.18.1",
    "@vscode/test-electron": "^2.5.2",
    "codemirror": "^6.0.2",
    "esbuild": "^0.28.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.8",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "y-codemirror.next": "^0.3.5",
    "y-prosemirror": "^1.3.7",
    "y-websocket": "^3.0.0"
  },
  "dependencies": {
    "markdown-it": "^14.1.1",
    "mermaid": "^11.14.0",
    "ws": "^8.20.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
  }
}
