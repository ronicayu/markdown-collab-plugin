.vscode/**
.vscode-test/**
src/**
out/test/**
**/*.test.ts
**/*.test.js
# Source maps are debug-only; never loaded at runtime.
**/*.map
# The host extension is bundled into out/extension.js (npm run bundle:extension),
# so node_modules runtime deps (markdown-it, yjs, y-protocols, lib0, ws, pako, …)
# are inlined and need not ship. The only exception is mermaid, which the webviews
# load as a script asset by URI rather than requiring it.
node_modules/**
!node_modules/mermaid/package.json
!node_modules/mermaid/dist/mermaid.min.js
tsconfig.json
tsconfig.webview.json
vitest.config.ts
.gitignore
.github/**
.claude/**
.markdown-collab/**
docs/**
package-lock.json
**/*.vsix
